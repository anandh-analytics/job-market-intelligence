{
  "source": "adzuna",
  "entity": "job_posting",
  "version": "silver_v1",

  "required_fields": [
    "source",
    "job_id",
    "title",
    "description",
    "company",
    "location",
    "category",
    "posted_at",
    "apply_url",
    "ingested_at"
  ],

  "optional_fields": [
